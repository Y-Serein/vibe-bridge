{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Bridge",
  "version": "0.1.0",
  "identifier": "com.serein.vibe-bridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vibe Bridge",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

